# LLM providers
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...

# Tools
TAVILY_API_KEY=tvly-...
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
GITHUB_TOKEN=ghp_...
GITHUB_DEFAULT_REPO=owner/repo

# Tracing (optional — earns +10% hackathon bonus)
# Get your key at https://app.omium.ai → Settings → API Keys
OMIUM_API_KEY=omium_...
OMIUM_PROJECT=omnibox
# Set to true if you see 502 errors at startup (skips workflow auto-registration)
OMIUM_SKIP_WORKFLOW_REGISTER=false

# Server
HOST=0.0.0.0
PORT=8000
DB_PATH=./omnibox.db
WORKSPACE_DIR=./workspace

# Worker
MAX_CONCURRENT_TASKS=5
LEASE_SECONDS=120
POLL_INTERVAL_SECONDS=1

# Dev — set to true to enable DEBUG-level logging
DEBUG=false
